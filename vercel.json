{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 300,
      "includeFiles": ["dist/**", "package.json"]
    }
  }
}
