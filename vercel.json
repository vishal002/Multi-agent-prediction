{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 300,
      "includeFiles": "{dist/**,lib/**,middleware/**,package.json,match_suggestions.json,litellm.config.yaml}"
    }
  }
}
