{
  "name": "ai-cricket-war-room",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/enrich-completed-matches.mjs",
    "build": "node scripts/build.mjs",
    "enrich": "node scripts/enrich-completed-matches.mjs",
    "start": "cross-env SERVE_DIST=1 node server.mjs",
    "start:dev": "node server.mjs",
    "ingestion:dev": "node scripts/run-uvicorn.mjs ingestion_service.app:app 3334",
    "judge:dev": "node scripts/run-uvicorn.mjs judge_service.app:app 8000",
    "dev:stack": "concurrently -n war,ing,jdg -c blue,green,magenta \"node server.mjs\" \"node scripts/run-uvicorn.mjs ingestion_service.app:app 3334\" \"node scripts/run-uvicorn.mjs judge_service.app:app 8000\"",
    "icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@sentry/node": "^9.5.0",
    "@supabase/supabase-js": "2.49.4",
    "@upstash/redis": "^1.34.3",
    "dotenv": "^16.4.7",
    "esbuild": "^0.28.0",
    "html-minifier": "^4.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18 <24"
  }
}
