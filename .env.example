# Copy this file to .env and fill in your keys.
# At least one LLM key is required.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Paid (Claude): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Force a provider: "groq" or "anthropic" (auto-selects if blank)
LLM_PROVIDER=

# Groq only: large model for judge + over-by-over JSON (default llama-3.3-70b-versatile)
# GROQ_MODEL=

# Groq only: smaller model for intel + debate + live % updates (saves tokens vs 70B)
# GROQ_MODEL_LIGHT=llama-3.1-8b-instant

# ── Live cricket scores (optional) ───────────────────────────────────────────
# Free tier (~100 calls/day): https://cricapi.com
CRICAPI_KEY=
