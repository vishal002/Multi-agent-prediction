# Copy this file to .env and fill in your keys.
# At least one LLM key is required.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Free tier (optional): https://aistudio.google.com/apikey — also accepts GOOGLE_API_KEY.
# With GROQ_API_KEY set, the Node proxy retries here when Groq is rate-limited / quota-blocked.
GEMINI_API_KEY=

# Default gemini-2.5-flash-lite (2.0-flash often shows free-tier limit:0 on some AI Studio projects).
# GEMINI_MODEL=gemini-2.5-flash
# Optional: comma-separated models to try after GEMINI_MODEL on quota errors.
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# Paid (Claude): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Force a provider: "groq" | "anthropic" | "gemini" (auto-selects if blank: groq → anthropic → gemini)
LLM_PROVIDER=groq

# Groq only: large model for judge + over-by-over JSON (default llama-3.3-70b-versatile)
# GROQ_MODEL=

# Groq only: smaller model for short intel + live % + misc turns (saves tokens vs 70B).
# Default llama-3.1-8b-instant. Free-tier TPM cap on this model is ~6k.
# GROQ_MODEL_LIGHT=llama-3.1-8b-instant

# Groq only: model for the 4-round debate. Defaults to GROQ_MODEL (70B) so the
# debate transcript runs on the larger 12k-TPM bucket instead of competing with
# the 8B intel burst for its 6k-TPM bucket. Set to llama-3.1-8b-instant to
# force everything onto the small model (relies on the server-side queue + 429
# retry to absorb the burst).
# GROQ_MODEL_DEBATE=llama-3.3-70b-versatile

# ── Live cricket scores (optional) ───────────────────────────────────────────
# Free tier (~100 calls/day): https://cricapi.com — set on the ingestion process env
CRICAPI_KEY=

# Node server proxies to these (defaults shown). If unset, use the uvicorn commands in server.mjs header.
# INGESTION_SERVICE_URL=http://127.0.0.1:3334
# JUDGE_SERVICE_URL=http://127.0.0.1:8000

# ── Vercel / production (Python not in the Node bundle) ────────────────────
# On Vercel, `api/index.mjs` imports the same router as `server.mjs`; ingestion
# and Judge stay separate processes. Point these at always-on (or serverless)
# URLs where you host the FastAPI apps — e.g. Render, Railway, Fly.io.
#
#   INGESTION_SERVICE_URL=https://your-ingestion.example.com
#   JUDGE_SERVICE_URL=https://your-judge.example.com
#
# Leave unset only for local dev with defaults above. `vercel.json` sets
# `maxDuration` 300s on the Node function; long LLM chains may still hit
# platform limits on free tier (60s) — use Vercel Pro and/or async pipelines
# if you need headroom (see project migration plan).

# ── Optional API hardening (see README “Server hardening”) ───────────────────
# Same random string on web + judge for JUDGE_SERVICE_SECRET when Judge is enabled.
# WAR_ROOM_API_SECRET=   # if set, browser must use localStorage.WAR_ROOM_API_SECRET + Bearer on LLM/Judge predict
# JUDGE_SERVICE_SECRET=
# TRUST_PROXY=1         # behind Render/nginx: rate limits use X-Forwarded-For
# ALLOWED_ORIGINS=https://yourdomain.com
# RL_MESSAGES_PER_MIN=30
# RL_JUDGE_PER_MIN=15
# JUDGE_ACCURACY_CACHE_MS=10000   # GET /api/judge/accuracy: cache upstream JSON (ms); 0 disables
# JUDGE_ACCURACY_UPSTREAM_MAX_RETRIES=3

# Short prediction links (/s/{id}) persist here (default: ./data/share_predictions.json under the app).
# On Render, attach a disk and point this at a path on that volume if you want links to survive redeploys.
# SHARE_PREDICTION_STORE_PATH=

# ── Judge DB: Turso (optional, judge service only) ───────────────────────────
# Free tier: https://turso.tech — libSQL remote; survives Render free restarts.
# When both are set, WAR_ROOM_DB_PATH is ignored for persistence.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# ── Supabase (optional — share links + Judge predictions in Postgres) ────────
# Create project at https://supabase.com and run `supabase/migrations/001_initial.sql`.
# Node (share_packs) and Judge (judge_predictions) use the service role key — never expose in the browser.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (optional — distributed rate limits + HTTP caches) ───────
# Vercel Marketplace → Upstash, or https://upstash.com — sets REST URL + token.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── LiteLLM proxy (optional — OpenAI-compatible router) ─────────────────────
# Run: pip install 'litellm[proxy]' && litellm --config litellm.config.yaml --port 4000
# LITELLM_BASE_URL=http://127.0.0.1:4000
# LITELLM_API_KEY=sk-cricket-war-room-dev   # must match litellm general_settings.master_key

# ── Sentry (optional — server errors) ───────────────────────────────────────
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Production CORS guard (optional) ──────────────────────────────────────────
# When NODE_ENV=production and this is set to 1, API routes refuse to start without ALLOWED_ORIGINS.
# ENFORCE_PRODUCTION_CORS=1

# ── Long jobs (optional — evaluate when hitting Vercel maxDuration) ─────────
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=
